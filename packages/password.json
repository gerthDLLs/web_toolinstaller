{
  "id": "password",
  "name": "Gerador de Senhas",
  "icon": "password",
  "width": 400,
  "height": 380,
  "css": ".pw-result{background:var(--bg-tertiary);border:1px solid var(--border-light);color:var(--text-primary);padding:12px 14px;border-radius:var(--radius);font-size:16px;font-family:Consolas,monospace;text-align:center;margin-bottom:12px;word-break:break-all;cursor:pointer}.pw-result:hover{background:var(--bg-surface)}.pw-opt{display:flex;align-items:center;gap:8px;padding:6px 0;font-size:13px;color:var(--text-secondary)}.pw-opt input[type=checkbox]{accent-color:var(--accent);width:16px;height:16px}.pw-opt input[type=range]{flex:1;accent-color:var(--accent)}.pw-opt label{min-width:80px}.pw-opt .pw-val{color:var(--text-primary);font-weight:600;min-width:20px;text-align:right}",
  "js": "AppManager.register('password',{init:function(b,win){b.innerHTML='<div style=\"font-size:18px;font-weight:600;color:var(--accent);text-align:center;margin-bottom:8px\">Gerador de Senhas</div><div id=\"pw-result\" class=\"pw-result\">Clique em Gerar</div><div class=\"pw-opt\"><label>Tamanho:</label><input id=\"pw-len\" type=\"range\" min=\"4\" max=\"32\" value=\"12\"/><span id=\"pw-len-val\" class=\"pw-val\">12</span></div><div class=\"pw-opt\"><input id=\"pw-up\" type=\"checkbox\" checked/><label>ABC</label><input id=\"pw-low\" type=\"checkbox\" checked/><label>abc</label><input id=\"pw-num\" type=\"checkbox\" checked/><label>123</label><input id=\"pw-sym\" type=\"checkbox\"/><label>!@#</label></div><button id=\"pw-gen\" class=\"btn btn-primary\" style=\"margin:8px auto 0\">Gerar Senha</button>';b.className='p-16 flex-col';var res=TK.byId('pw-result');var lenS=TK.byId('pw-len');var lenV=TK.byId('pw-len-val');function gen(){var chars='';if(TK.byId('pw-up').checked)chars+='ABCDEFGHIJKLMNOPQRSTUVWXYZ';if(TK.byId('pw-low').checked)chars+='abcdefghijklmnopqrstuvwxyz';if(TK.byId('pw-num').checked)chars+='0123456789';if(TK.byId('pw-sym').checked)chars+='!@#$%^&*()_+-=[]{}|;:,.<>?';if(!chars){res.textContent='Selecione ao menos um tipo';return}var len=parseInt(lenS.value);var pwd='';for(var i=0;i<len;i++)pwd+=chars[Math.floor(Math.random()*chars.length)];res.textContent=pwd}lenS.oninput=function(){lenV.textContent=this.value};TK.byId('pw-gen').onclick=gen;res.onclick=function(){if(res.textContent&&res.textContent!=='Clique em Gerar'&&res.textContent!=='Selecione ao menos um tipo'){navigator.clipboard.writeText(res.textContent).then(function(){var t=res.textContent;res.textContent='Copiado!';setTimeout(function(){res.textContent=t},1000)})}};gen()}})"
}
