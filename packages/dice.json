{
  "id": "dice",
  "name": "Dados",
  "icon": "dice",
  "width": 360,
  "height": 420,
  "css": ".dice-select{background:var(--bg-tertiary);border:1px solid var(--border-light);color:var(--text-primary);padding:4px 8px;border-radius:var(--radius);font-size:13px;outline:none;cursor:pointer}.dice-entry{background:var(--bg-secondary);padding:6px 12px;border-radius:var(--radius);font-size:13px;color:var(--text-secondary)}",
  "js": "AppManager.register('dice',{init:function(b,win){b.innerHTML='<div style=\"font-size:18px;font-weight:600;color:var(--accent);text-align:center\">Dados</div><div id=\"dice-val\" style=\"font-size:64px;font-weight:300;color:var(--text-primary);text-align:center;padding:16px\">0</div><div class=\"flex items-center gap-8 justify-center\" style=\"margin-bottom:12px\"><label style=\"color:var(--text-secondary);font-size:13px\">Dado:</label><select id=\"dice-type\" class=\"dice-select\"><option>d4</option><option selected>d6</option><option>d8</option><option>d10</option><option>d12</option><option>d20</option></select><label style=\"color:var(--text-secondary);font-size:13px\">Qtd:</label><select id=\"dice-cnt\" class=\"dice-select\"><option>1</option><option>2</option><option>3</option><option>4</option><option>5</option><option>6</option><option>7</option><option>8</option><option>9</option><option>10</option></select></div><button id=\"dice-btn\" class=\"btn btn-primary\" style=\"margin:0 auto 12px\">Rolar</button><div id=\"dice-hist\" style=\"flex:1;overflow:auto;display:flex;flex-direction:column;gap:4px\"></div>';b.className='p-16 flex-col';var btn=TK.byId('dice-btn');btn.onclick=function(){var s=parseInt(TK.byId('dice-type').value.slice(1));var c=parseInt(TK.byId('dice-cnt').value);var t=0,r=[];for(var i=0;i<c;i++){var v=Math.floor(Math.random()*s)+1;r.push(v);t+=v}TK.byId('dice-val').textContent=t;var e=TK.el('div',{className:'dice-entry'},c+'d'+s+': '+r.join(', ')+' = '+t);var h=TK.byId('dice-hist');h.insertBefore(e,h.firstChild)}}})"
}
